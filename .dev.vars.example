# Cloudflare Access (required in production). TEAM_DOMAIN may be the base Access URL or the full /cdn-cgi/access/certs URL.
POLICY_AUD=your-access-policy-audience-tag
TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Nimblersoft bridge integration (agentic-inbox-bridge). Optional for local dev.
# WEBHOOK_URL also lives in wrangler.jsonc vars; WEBHOOK_SECRET is a Worker secret in prod.
WEBHOOK_URL=https://mail-bridge.nimblersoft.com/webhooks/agentic-inbox
WEBHOOK_SECRET=local-dev-shared-secret
